{
  "DSL Route builder": {
    "scope": "python",
    "prefix": "dsl-route",
    "body": [
      "from app.dsl.builder import RouteBuilder",
      "",
      "route = (",
      "    RouteBuilder.from_(\"${1:route.id}\", source=\"${2:internal:source}\")",
      "    .$0",
      "    .build()",
      ")"
    ],
    "description": "New DSL Route with RouteBuilder"
  },
  "DSL ETL pipeline": {
    "scope": "python",
    "prefix": "dsl-etl",
    "body": [
      "route = (",
      "    RouteBuilder.from_(\"${1:etl.import}\", source=\"timer:${2:60}s\")",
      "    .timer(interval_seconds=${2:60})",
      "    .poll(\"${3:source.fetch}\")",
      "    .normalize()",
      "    .sort(key_field=\"${4:created_at}\")",
      "    .dispatch_action(\"${5:analytics.insert_batch}\")",
      "    .on_error(action=\"dlq.handle\")",
      "    .build()",
      ")"
    ],
    "description": "Timer-based ETL with polling + normalize + sort"
  },
  "DSL AI Q&A pipeline": {
    "scope": "python",
    "prefix": "dsl-ai-qa",
    "body": [
      "route = (",
      "    RouteBuilder.from_(\"${1:ai.qa}\", source=\"internal:ai\")",
      "    .rag_search(query_field=\"${2:question}\", top_k=${3:5})",
      "    .compose_prompt(template=\"Context: {context}\\n\\nQ: {${2:question}}\\nA:\")",
      "    .token_budget(max_tokens=${4:4096})",
      "    .sanitize_pii()",
      "    .call_llm(provider=\"${5:claude}\")",
      "    .restore_pii()",
      "    .guardrails()",
      "    .build()",
      ")"
    ],
    "description": "AI Q&A with RAG, PII masking, guardrails"
  },
  "DSL webhook handler": {
    "scope": "python",
    "prefix": "dsl-webhook",
    "body": [
      "route = (",
      "    RouteBuilder.from_(\"${1:webhook.event}\", source=\"webhook:/${2:event-type}\")",
      "    .require_header(\"X-Webhook-Signature\")",
      "    .require_fields(${3:\"id\", \"event_type\"})",
      "    .idempotent(lambda ex: ex.in_message.body.get(\"id\", \"\"))",
      "    .dispatch_action(\"${4:events.process}\")",
      "    .on_error(action=\"dlq.webhook\")",
      "    .build()",
      ")"
    ],
    "description": "Webhook handler with signature + idempotency"
  },
  "DSL scraping pipeline": {
    "scope": "python",
    "prefix": "dsl-scrape",
    "body": [
      "route = (",
      "    RouteBuilder.from_(\"${1:scrape.target}\", source=\"timer:${2:300}s\")",
      "    .timer(interval_seconds=${2:300})",
      "    .scrape(\"${3:https://example.com}\", selectors={\"title\": \"h1\", \"price\": \".price\"})",
      "    .paginate(next_selector=\".next\", max_pages=${4:10})",
      "    .dispatch_action(\"${5:analytics.insert_batch}\")",
      "    .build()",
      ")"
    ],
    "description": "Web scraping with pagination"
  },
  "DSL CRUD with audit": {
    "scope": "python",
    "prefix": "dsl-crud",
    "body": [
      "route = (",
      "    RouteBuilder.from_(\"${1:entity}.create\", source=\"internal:${1:entity}\")",
      "    .require_auth()",
      "    .validate(${2:EntitySchema})",
      "    .dispatch_action(\"${1:entity}.add\").as_(\"created\")",
      "    .publish_event(\"events.${1:entity}\")",
      "    .on_completion(processors=[LogProcessor()])",
      "    .build()",
      ")"
    ],
    "description": "CRUD with auth, validation, event publish, audit"
  },
  "Register action decorator": {
    "scope": "python",
    "prefix": "register-action",
    "body": [
      "@register_action(\"${1:domain.action}\", payload_model=${2:PayloadSchema})",
      "async def ${3:method_name}(self, ${4:param}: ${5:type}) -> ${6:dict}:",
      "    \"\"\"${7:Description.}\"\"\"",
      "    $0"
    ],
    "description": "Register service method as DSL action"
  }
}
