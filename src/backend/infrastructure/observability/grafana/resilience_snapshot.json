{
  "uid": "gd-resilience-snapshot",
  "title": "Resilience Snapshot (CB / RateLimit / Bulkhead matrix)",
  "tags": ["gd_integration_tools", "K2-S7", "resilience"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Circuit Breakers (state matrix)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"__name__": true, "instance": true, "job": true},
            "renameByName": {"name": "Breaker", "host": "Host", "Value": "State (0=closed,1=half-open,2=open)"}
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Rate Limiters (per resource)",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate_limiter_tokens_available",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bulkhead in-flight tasks (per resource)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "bulkhead_in_flight",
          "legendFormat": "{{resource}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Degradation events (per chain)",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (chain) (rate(resilience_degradation_total[5m]))",
          "legendFormat": "{{chain}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CB transitions (open / half-open / closed)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (state) (rate(circuit_breaker_transition_total[5m]))", "legendFormat": "{{state}}", "refId": "A"}
      ]
    }
  ]
}
