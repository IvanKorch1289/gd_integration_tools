# ──────────────────────────────────────────────────────────────────────
# .env.example — все секреты приложения, сгруппированы по env_prefix.
# Поддерживается актуальным через `python tools/config_audit.py`.
#
# Правило: в этом файле — ТОЛЬКО чувствительные значения (api_key,
# password, secret, token, login). URL'ы, имена моделей, хосты, порты,
# таймауты — в config_profiles/{profile}.yml.
# Никаких секретов в config_profiles/*.yml — только в этом файле и Vault.
# ──────────────────────────────────────────────────────────────────────

# Active profile (dev | dev_light | staging | prod)
APP_PROFILE=dev

# ──────────────────────────────────────────────────────────────────────
# Vault
# enabled — управляется через config_profiles/{profile}.yml::vault.enabled.
# Переменная VAULT_ENABLED при наличии работает как override (true/false).
# VAULT_ADDR / VAULT_SECRET_PATH — задаются в config_profiles/*.yml::vault.
# ──────────────────────────────────────────────────────────────────────
VAULT_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Database (DB_*)
# DB_NAME — нечувствительный, задаётся в config_profiles/*.yml::database.name.
# ──────────────────────────────────────────────────────────────────────
DB_USERNAME=
DB_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# External Databases (EXT_DB_<PROFILE>_*)
# Per-connection secrets — формат: EXT_DB_<PROFILE_NAME>_USERNAME / _PASSWORD
# Пример для профилей oracle_1 / pg_1:
#   EXT_DB_ORACLE_1_USERNAME=
#   EXT_DB_ORACLE_1_PASSWORD=
#   EXT_DB_PG_1_USERNAME=
#   EXT_DB_PG_1_PASSWORD=
# ──────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────
# Mongo (MONGO_*)
# ──────────────────────────────────────────────────────────────────────
MONGO_USERNAME=
MONGO_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Redis (REDIS_*)
# ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# RabbitMQ / Queue (QUEUE_*)
# ──────────────────────────────────────────────────────────────────────
QUEUE_USERNAME=
QUEUE_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Mail / SMTP (MAIL_*)
# ──────────────────────────────────────────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# File Storage (FS_*)
# ──────────────────────────────────────────────────────────────────────
FS_ACCESS_KEY=
FS_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────
# Elasticsearch (ES_*)
# ──────────────────────────────────────────────────────────────────────
ES_API_KEY=
ES_USERNAME=
ES_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# ClickHouse (CLICKHOUSE_*)
# ──────────────────────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=

# ──────────────────────────────────────────────────────────────────────
# Logging / Graylog (LOG_*)
# Подключённые через Settings: LOG_HOST/PORT/UDP_PORT/USE_TLS/... — задаются
# в config_profiles/*.yml::log. Здесь — только секреты Graylog-стенда.
# ──────────────────────────────────────────────────────────────────────
LOG_PASSWORD_SECRET=
LOG_ROOT_PASSWORD_SHA2=

# ──────────────────────────────────────────────────────────────────────
# AI providers — только api_key. URL/модели/таймауты — в base.yml.
# Подключённые через Settings: HUGGINGFACE_, PERPLEXITY_, OPEN_WEBUI_,
# OPENROUTER_, NIM_, OPENAI_. GIGACHAT_/TAVILY_ — внешние ключи,
# собственного Settings-класса пока нет.
# ──────────────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=
PERPLEXITY_API_KEY=
OPEN_WEBUI_API_KEY=
OPENROUTER_API_KEY=
NIM_API_KEY=
OPENAI_API_KEY=
GIGACHAT_API_KEY=
TAVILY_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# RAG (RAG_*)
# ──────────────────────────────────────────────────────────────────────
RAG_QDRANT_API_KEY=
RAG_EMBEDDING_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# External APIs
# ──────────────────────────────────────────────────────────────────────
SKB_API_KEY=
DADATA_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Security (SEC_*)
# ──────────────────────────────────────────────────────────────────────
SEC_SECRET_KEY=
SEC_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Bot integrations
# ──────────────────────────────────────────────────────────────────────
EXPRESS_SIGNATURE_SECRET=
EXPRESS_SECRET_KEY=
TELEGRAM_SIGNATURE_SECRET=
TELEGRAM_SECRET_KEY=
