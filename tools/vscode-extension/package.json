{
  "name": "gd-integration-tools",
  "displayName": "GD Integration Tools",
  "description": "K5 S19 W2 + S33 W5: VSCode extension for GD Integration Tools — syntax highlighting, wizard commands, DSL-aware editing for .dsl.yaml and route.toml",
  "version": "0.1.0",
  "publisher": "k5-frontend-dx",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:yaml",
    "onLanguage:toml",
    "onCommand:gd-integration-tools.runStep",
    "workspaceContains:**/*.dsl.yaml",
    "workspaceContains:**/route.toml",
    "workspaceContains:**/plugin.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gd-dsl",
        "aliases": ["GD DSL", "gd-dsl"],
        "extensions": [".gd", ".gds"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "dsl-yaml",
        "aliases": ["DSL YAML"],
        "filenames": ["*.dsl.yaml"],
        "filenamePatterns": ["**/routes/**/*.yaml"]
      },
      {
        "id": "dsl-toml",
        "aliases": ["DSL TOML"],
        "filenames": ["plugin.toml", "route.toml"]
      }
    ],
    "grammars": [
      {
        "language": "gd-dsl",
        "scopeName": "source.gd-dsl",
        "path": "./syntaxes/gd-dsl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "gd-integration-tools.runStep",
        "title": "GD: Run Step",
        "category": "GD Integration",
        "description": "Run the current DSL step"
      },
      {
        "command": "gd-integration-tools.showDocs",
        "title": "GD: Show Documentation",
        "category": "GD Integration",
        "description": "Show documentation for current element"
      },
      {
        "command": "gd-integration-tools.wizardRoute",
        "title": "GD: Scaffold Route (make wizard-route)",
        "category": "GD Integration Tools",
        "description": "Run the interactive route wizard — creates routes/<name>/route.toml + *.dsl.yaml"
      },
      {
        "command": "gd-integration-tools.wizardPlugin",
        "title": "GD: Scaffold Plugin (make wizard-plugin)",
        "category": "GD Integration Tools",
        "description": "Run the interactive plugin wizard — creates extensions/<name>/"
      },
      {
        "command": "gd-integration-tools.openRoutesFolder",
        "title": "GD: Open Routes Folder",
        "category": "GD Integration Tools",
        "description": "Open the routes/ folder in VSCode explorer"
      },
      {
        "command": "gd-integration-tools.openExtensionsFolder",
        "title": "GD: Open Extensions Folder",
        "category": "GD Integration Tools",
        "description": "Open the extensions/ folder in VSCode explorer"
      },
      {
        "command": "gd-integration-tools.validateRoute",
        "title": "GD: Validate Route",
        "category": "GD Integration Tools",
        "description": "Run 'make routes' to validate the current route"
      }
    ],
    "codeLens": [
      {
        "language": "gd-dsl",
        "source": "gd-integration-tools",
        "command": "gd-integration-tools.runStep"
      }
    ],
    "hoverProvider": [
      {
        "language": "gd-dsl",
        "command": "gd-integration-tools.showDocs"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder == true && resourceLabel == 'routes'",
          "command": "gd-integration-tools.wizardRoute",
          "group": "gd@1"
        },
        {
          "when": "explorerResourceIsFolder == true && resourceLabel == 'extensions'",
          "command": "gd-integration-tools.wizardPlugin",
          "group": "gd@1"
        },
        {
          "when": "explorerResourceIsFolder == true",
          "command": "gd-integration-tools.openRoutesFolder",
          "group": "gd@10"
        }
      ],
      "commandPalette": [
        {
          "command": "gd-integration-tools.wizardRoute",
          "when": "false"
        },
        {
          "command": "gd-integration-tools.wizardPlugin",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "GD Integration Tools",
      "properties": {
        "gdIntegrationTools.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable LSP client for enhanced features"
        },
        "gdIntegrationTools.lsp.server": {
          "type": "string",
          "default": "localhost:8765",
          "description": "LSP server address"
        },
        "gdIntegrationTools.pythonCommand": {
          "type": "string",
          "default": "uv run python",
          "description": "Python command to use for wizard CLIs (e.g. 'uv run python', 'python3')"
        },
        "gdIntegrationTools.routesDir": {
          "type": "string",
          "default": "routes",
          "description": "Relative path to routes directory"
        },
        "gdIntegrationTools.extensionsDir": {
          "type": "string",
          "default": "extensions",
          "description": "Relative path to extensions directory"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "cd client && npm install",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
