# V11 plugin manifest — сгенерирован tools/codegen_plugin.py.
# Полное описание формата — docs/adr/ADR-042-plugin-toml-schema.md.
# Каталог capabilities — docs/adr/ADR-044-capability-vocabulary.md.

name = "{{ name }}"
version = "0.1.0"
requires_core = ">=0.2,<0.3"
entry_class = "extensions.{{ name }}.plugin.{{ pascal_name }}Plugin"
tenant_aware = false
description = "Auto-generated V11 plugin scaffold ({{ name }})."

{% if capabilities -%}
# ─── Runtime capabilities (sandbox gate) ──────────────────────────
{% for cap in capabilities %}
[[capabilities]]
name = "{{ cap }}"
scope = "{{ name }}.*"
{% endfor %}
{%- endif %}

# ─── Декларативный inventory ──────────────────────────────────────
[provides]
actions = [
{%- for feature in features %}
    "{{ name }}.{{ feature }}",
{%- endfor %}
]
