{
  "uid": "gd-slo-burn-rate",
  "title": "SLO Burn Rate (multi-window 1h / 6h / 24h)",
  "tags": ["gd_integration_tools", "K2-S7", "slo"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "1m",
  "time": {"from": "now-30d", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "slo_target",
        "type": "constant",
        "current": {"text": "0.999", "value": "0.999"}
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Error Budget Remaining (30d)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red"}, {"color": "orange", "value": 0.10}, {"color": "green", "value": 0.50}]}}},
      "targets": [
        {
          "expr": "1 - ((1 - sum(rate(http_requests_total{service=\"$service\",status_code!~\"5..\"}[30d])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[30d])), 1)) / (1 - $slo_target))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Burn rate 1h",
      "datasource": "Prometheus",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 6},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 3}, {"color": "red", "value": 14.4}]}}},
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[1h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[1h])), 1)) / (1 - $slo_target)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Burn rate 6h",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 6},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 2}, {"color": "red", "value": 6}]}}},
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[6h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[6h])), 1)) / (1 - $slo_target)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Burn rate 24h",
      "datasource": "Prometheus",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 6},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 1}, {"color": "red", "value": 3}]}}},
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[24h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[24h])), 1)) / (1 - $slo_target)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Burn rate timeline (1h / 6h / 24h)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 10},
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[1h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[1h])), 1)) / (1 - $slo_target)",
          "legendFormat": "1h",
          "refId": "A"
        },
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[6h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[6h])), 1)) / (1 - $slo_target)",
          "legendFormat": "6h",
          "refId": "B"
        },
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\",status_code=~\"5..\"}[24h])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[24h])), 1)) / (1 - $slo_target)",
          "legendFormat": "24h",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error budget consumption (30d window)",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [
        {
          "expr": "(1 - sum(rate(http_requests_total{service=\"$service\",status_code!~\"5..\"}[30d])) / clamp_min(sum(rate(http_requests_total{service=\"$service\"}[30d])), 1)) / (1 - $slo_target)",
          "legendFormat": "consumed",
          "refId": "A"
        }
      ]
    }
  ]
}
