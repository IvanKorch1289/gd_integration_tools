# V11 route-manifest — feature ``{{ feature }}`` плагина ``{{ name }}``.
# Только мандатные поля — К2 расширит схему аддитивно.

name = "{{ name }}.{{ feature }}"
version = "0.1.0"

[from]
http = { method = "POST", path = "/api/v1/{{ name }}/{{ feature }}" }

[to]
response = { code = 200, body = "${body}" }
