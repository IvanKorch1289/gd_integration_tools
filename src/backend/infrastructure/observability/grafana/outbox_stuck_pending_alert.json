{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "outbox-stuck-pending",
      "folder": "gd-integration-tools",
      "interval": "1m",
      "rules": [
        {
          "uid": "outbox-stuck-pending-high",
          "title": "OutboxStuckPendingHigh",
          "condition": "C",
          "for": "5m",
          "noDataState": "OK",
          "execErrState": "Alerting",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": {"from": 600, "to": 0},
              "datasourceUid": "prometheus",
              "model": {
                "expr": "outbox_stuck_pending_count",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": {"from": 0, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "type": "reduce",
                "expression": "A",
                "reducer": "last",
                "refId": "B"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": {"from": 0, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "type": "threshold",
                "expression": "B",
                "conditions": [
                  {
                    "type": "query",
                    "evaluator": {"type": "gt", "params": [0]},
                    "operator": {"type": "and"},
                    "query": {"params": ["B"]},
                    "reducer": {"type": "last", "params": []}
                  }
                ],
                "refId": "C"
              }
            }
          ],
          "labels": {
            "severity": "warning",
            "service": "outbox-dispatcher",
            "sprint": "S72-W2",
            "team": "platform"
          },
          "annotations": {
            "summary": "Outbox worker is stuck — pending messages not being processed",
            "description": "outbox_stuck_pending_count > 0 for 5+ minutes. Worker dispatcher likely crashed/deadlocked. Check src/backend/infrastructure/messaging/outbox/dispatcher.py and recovery runbook at observability/grafana/outbox_stuck_pending.json (Runbook panel).",
            "runbook_url": "https://wiki.internal/runbooks/outbox-stuck-pending",
            "dashboard": "/d/gd-outbox-stuck-pending"
          }
        },
        {
          "uid": "outbox-stuck-pending-critical",
          "title": "OutboxStuckPendingCritical",
          "condition": "C",
          "for": "15m",
          "noDataState": "OK",
          "execErrState": "Alerting",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": {"from": 900, "to": 0},
              "datasourceUid": "prometheus",
              "model": {
                "expr": "outbox_stuck_pending_count",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": {"from": 0, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "type": "reduce",
                "expression": "A",
                "reducer": "last",
                "refId": "B"
              }
            },
            {
              "refId": "C",
              "queryType": "",
              "relativeTimeRange": {"from": 0, "to": 0},
              "datasourceUid": "__expr__",
              "model": {
                "type": "threshold",
                "expression": "B",
                "conditions": [
                  {
                    "type": "query",
                    "evaluator": {"type": "gt", "params": [100]},
                    "operator": {"type": "and"},
                    "query": {"params": ["B"]},
                    "reducer": {"type": "last", "params": []}
                  }
                ],
                "refId": "C"
              }
            }
          ],
          "labels": {
            "severity": "critical",
            "service": "outbox-dispatcher",
            "sprint": "S72-W2",
            "team": "platform"
          },
          "annotations": {
            "summary": "Outbox worker is severely stuck — > 100 pending messages older than 5min",
            "description": "outbox_stuck_pending_count > 100 for 15+ minutes. P0 incident: business-critical messages not being delivered. Immediate intervention required. See runbook at observability/grafana/outbox_stuck_pending.json.",
            "runbook_url": "https://wiki.internal/runbooks/outbox-stuck-pending",
            "dashboard": "/d/gd-outbox-stuck-pending"
          }
        }
      ]
    }
  ]
}
