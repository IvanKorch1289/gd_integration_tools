{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Infrastructure Health — клиентские пулы, circuit breakers, request latency, error rate. Базируется на метриках infra_client_* (IL1.2) + dsl_pipeline_* / connection_pool_utilization.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "gd-infrastructure-health",
  "title": "GD Integration Tools — Infrastructure Health",
  "tags": ["gd-integration", "infrastructure", "il-obs1", "client", "resilience"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "client",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 2,
        "query": "label_values(infra_client_requests_total, client)",
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Client Pool Saturation",
      "description": "active / max. >0.85 = warning, >0.95 = critical.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (client) (infra_client_pool_size{state=\"active\",client=~\"$client\"}) / clamp_min(sum by (client) (infra_client_pool_size{state=\"max\",client=~\"$client\"}), 1)",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.7, "color": "yellow"},
              {"value": 0.9, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "title": "Circuit Breaker State (0 closed / 1 half-open / 2 open)",
      "description": "infra_client_circuit_state — 2 (OPEN) означает полное отключение клиента.",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "infra_client_circuit_state{client=~\"$client\"}",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 2, "color": "red"}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}}},
            {"type": "value", "options": {"1": {"text": "HALF-OPEN", "color": "yellow"}}},
            {"type": "value", "options": {"2": {"text": "OPEN", "color": "red"}}}
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false}
      }
    },
    {
      "id": 3,
      "title": "Client Request Latency P50/P95/P99 (s)",
      "description": "Percentile latency по infra_client_request_duration_seconds_bucket.",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, client) (rate(infra_client_request_duration_seconds_bucket{client=~\"$client\"}[5m])))",
          "legendFormat": "P50 {{client}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, client) (rate(infra_client_request_duration_seconds_bucket{client=~\"$client\"}[5m])))",
          "legendFormat": "P95 {{client}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, client) (rate(infra_client_request_duration_seconds_bucket{client=~\"$client\"}[5m])))",
          "legendFormat": "P99 {{client}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 2, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["last", "max", "mean"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 4,
      "title": "Request Rate by Outcome",
      "description": "sum by (outcome) (rate(infra_client_requests_total[1m])) — success / error / timeout / ...",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (outcome) (rate(infra_client_requests_total{client=~\"$client\"}[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"fillOpacity": 30, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "mean"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 5,
      "title": "Reconnection Attempts (rate / 5m)",
      "description": "infra_client_reconnect_attempts_total — sharp spikes сигнализируют нестабильность downstream.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (client) (rate(infra_client_reconnect_attempts_total{client=~\"$client\"}[5m]))",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 6,
      "title": "Connection Pool Utilization (legacy dsl metric)",
      "description": "connection_pool_utilization per pool_name (db / redis / kafka).",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "connection_pool_utilization",
          "legendFormat": "{{pool_name}}/{{metric}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 7,
      "title": "DSL Pipeline Error Rate (%)",
      "description": "100 * errors / total за 5 минут. >5% — warning, >10% — critical.",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum(rate(dsl_pipeline_execution_total{status=\"error\"}[5m])) / clamp_min(sum(rate(dsl_pipeline_execution_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 5, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false}
      }
    }
  ]
}
