{
  "version": "2.0",
  "created_at": "2026-05-14",
  "sprint": "S6",
  "owner": "K2 Resilience+Performance",
  "description": "Sprint 6 K2 perf-gate baseline (1000 RPS sustained + 5000 RPS spike). Перегенерируется через make perf-baseline после staging-smoke. Feature-flag: perf_gate_strict (default-OFF, warn-only до S7).",
  "profile": {
    "sustained": {
      "duration_s": 60,
      "rps_target": 1000,
      "vus": 200,
      "ramp_up_s": 10,
      "ramp_down_s": 10
    },
    "spike": {
      "duration_s": 10,
      "rps_target": 5000,
      "vus": 1000,
      "baseline_s": 5,
      "recovery_s": 5
    }
  },
  "endpoints": {
    "GET /api/v1/health": {
      "p95_ms": 50.0,
      "p99_ms": 100.0,
      "rps_floor": 600.0,
      "weight": 0.6,
      "description": "Middleware overhead probe"
    },
    "GET /api/v1/admin/users": {
      "p95_ms": 200.0,
      "p99_ms": 500.0,
      "rps_floor": 250.0,
      "weight": 0.3,
      "description": "DB pool round-trip"
    },
    "POST /api/v1/credit/check": {
      "p95_ms": 800.0,
      "p99_ms": 1500.0,
      "rps_floor": 80.0,
      "weight": 0.1,
      "description": "extensions/credit_pipeline e2e"
    }
  },
  "global": {
    "p95_ms": 200.0,
    "error_rate_max": 0.01,
    "rps_floor": 1000.0
  },
  "ci": {
    "warn_only": true,
    "continue_on_error": true,
    "feature_flag": "perf_gate_strict",
    "note": "Перейти на blocking когда feature_flag перейдёт в default-ON (S7+)."
  }
}
