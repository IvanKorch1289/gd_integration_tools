{
  "uid": "gd-dlq-per-transport",
  "title": "DLQ per-transport breakdown (S9 K2 W4)",
  "tags": ["gd_integration_tools", "S9-K2", "dlq", "transport"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "transport",
        "type": "query",
        "query": "label_values(dlq_depth, transport)",
        "datasource": "Prometheus",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "DLQ depth — HTTP transport",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}
        }
      },
      "targets": [
        {"expr": "sum(dlq_depth{transport=\"http\"})", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DLQ depth — SOAP transport",
      "datasource": "Prometheus",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}
        }
      },
      "targets": [
        {"expr": "sum(dlq_depth{transport=\"soap\"})", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DLQ depth — gRPC transport",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}
        }
      },
      "targets": [
        {"expr": "sum(dlq_depth{transport=\"grpc\"})", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DLQ depth — Webhook transport",
      "datasource": "Prometheus",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}
        }
      },
      "targets": [
        {"expr": "sum(dlq_depth{transport=\"webhook\"})", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DLQ writes/sec per transport",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 9},
      "targets": [
        {"expr": "sum by (transport) (rate(dlq_writes_total[5m]))", "legendFormat": "{{transport}}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "DLQ breakdown by reason",
      "datasource": "Prometheus",
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (reason) (dlq_depth{transport=~\"$transport\"})", "legendFormat": "{{reason}}", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top failing routes by DLQ writes",
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (route_id, transport) (rate(dlq_writes_total[5m])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "annotations": {
    "list": []
  }
}
